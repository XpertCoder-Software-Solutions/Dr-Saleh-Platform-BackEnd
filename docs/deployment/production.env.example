# Copy to /etc/dr-saleh-api/.env on EC2 and replace every <...> value.
# Do not commit the real production .env.

NODE_ENV=production
PORT=3000
API_PREFIX=api
LOG_LEVEL=info
SWAGGER_ENABLED=false

DATABASE_URL=postgresql://<db_user>:<db_password>@<rds-endpoint>.rds.amazonaws.com:5432/<db_name>?schema=public&sslmode=require&connect_timeout=30&pool_timeout=30
DATABASE_SSL_MODE=require
PRISMA_QUERY_TIMEOUT_MS=30000

INITIAL_ADMIN_FULL_NAME="<initial_admin_full_name>"
INITIAL_ADMIN_EMAIL=<initial_admin_email>
INITIAL_ADMIN_PHONE_NUMBER=<initial_admin_phone>
INITIAL_ADMIN_PASSWORD=<one-time-strong-initial-admin-password>

APP_PUBLIC_URL=https://api.<your-domain>
APP_PLATFORM_URL=https://<frontend-domain>
BRAND_LOGO_PATH=/brand/logo.png
BRAND_NAME="Dr. Saleh Platform"
SUPPORT_EMAIL=<support-email>
ADMIN_NOTIFICATION_EMAIL=<admin-notification-email>

BREVO_API_KEY=<brevo-production-api-key>
BREVO_SENDER_NAME="Dr. Saleh Platform"
BREVO_SENDER_EMAIL=<verified-brevo-sender-email>

JWT_ACCESS_SECRET=<64-plus-character-random-access-secret>
JWT_REFRESH_SECRET=<64-plus-character-random-refresh-secret>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CORS_ALLOWED_ORIGINS=https://<frontend-domain>,https://<admin-frontend-domain>
CORS_CREDENTIALS=true

THROTTLE_TTL=60000
THROTTLE_LIMIT=100

REDIS_HOST=<elasticache-primary-endpoint>
REDIS_PORT=6379
REDIS_DB=0
REDIS_TLS=true
REDIS_USERNAME=
REDIS_PASSWORD=<redis-auth-token-if-enabled>

AWS_REGION=<aws-region>
AWS_S3_BUCKET_NAME=<private-content-bucket>
AWS_ACCESS_KEY_ID=<least-privilege-app-access-key-or-use-instance-role>
AWS_SECRET_ACCESS_KEY=<least-privilege-app-secret-key-or-use-instance-role>
AWS_S3_ENDPOINT=
AWS_S3_FORCE_PATH_STYLE=false

CLOUDFRONT_DOMAIN=<distribution-domain-or-cname>
CLOUDFRONT_KEY_PAIR_ID=<cloudfront-key-pair-id>
CLOUDFRONT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<escaped-private-key-lines>\n-----END PRIVATE KEY-----"

FAWRY_BASE_URL=<fawry-production-base-url>
FAWRY_MERCHANT_CODE=<fawry-merchant-code>
FAWRY_SECURITY_KEY=<fawry-security-key>
FAWRY_RETURN_URL=https://<frontend-domain>/payment/fawry/return
FAWRY_NOTIFICATION_URL=https://api.<your-domain>/api/payments/fawry/webhook

PAYPAL_CLIENT_ID=<paypal-production-client-id>
PAYPAL_CLIENT_SECRET=<paypal-production-client-secret>
PAYPAL_BASE_URL=https://api-m.paypal.com
PAYPAL_WEBHOOK_ID=<paypal-production-webhook-id>

REFERRAL_REWARD_TYPE=PERCENTAGE
REFERRAL_REWARD_VALUE=10
REFERRAL_COUPON_EXPIRES_DAYS=30
