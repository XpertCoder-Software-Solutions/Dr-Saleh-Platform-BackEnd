{
  "info": {
    "_postman_id": "3f740d8a-97cb-4ff7-9c72-2989cbf72871",
    "name": "Dr. Saleh Platform - Wishlist",
    "description": "Wishlist API examples for authenticated users.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "wishlistId",
      "value": "d98fb0df-d660-443b-bbb5-980f32cba086"
    },
    {
      "key": "bookId",
      "value": "7cb9f85b-420f-4f4e-9330-85ab0675df90"
    },
    {
      "key": "courseId",
      "value": "54762f75-d3e2-4efb-8dcb-2a37a1a2bf56"
    },
    {
      "key": "productId",
      "value": "9b93af31-02c4-40f8-9b28-bb7aa806c891"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Add Book To Wishlist",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"itemType\": \"BOOK\",\n  \"itemId\": \"{{bookId}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/wishlist",
          "host": ["{{baseUrl}}"],
          "path": ["wishlist"]
        },
        "description": "Returns 201 Created. Repeating the same item for the same user returns 409 Conflict."
      },
      "response": []
    },
    {
      "name": "Add Course To Wishlist",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"itemType\": \"COURSE\",\n  \"itemId\": \"{{courseId}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/wishlist",
          "host": ["{{baseUrl}}"],
          "path": ["wishlist"]
        }
      },
      "response": []
    },
    {
      "name": "Add Product To Wishlist",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"itemType\": \"PRODUCT\",\n  \"itemId\": \"{{productId}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/wishlist",
          "host": ["{{baseUrl}}"],
          "path": ["wishlist"]
        }
      },
      "response": []
    },
    {
      "name": "Get My Wishlist",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/wishlist?page=1&limit=20",
          "host": ["{{baseUrl}}"],
          "path": ["wishlist"],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "20"
            },
            {
              "key": "itemType",
              "value": "BOOK",
              "disabled": true
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Check Book In Wishlist",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/wishlist/check?itemType=BOOK&itemId={{bookId}}",
          "host": ["{{baseUrl}}"],
          "path": ["wishlist", "check"],
          "query": [
            {
              "key": "itemType",
              "value": "BOOK"
            },
            {
              "key": "itemId",
              "value": "{{bookId}}"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Remove Wishlist Item",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/wishlist/{{wishlistId}}",
          "host": ["{{baseUrl}}"],
          "path": ["wishlist", "{{wishlistId}}"]
        },
        "description": "Deletes only the current user's own wishlist item."
      },
      "response": []
    }
  ]
}
