NODE_ENV=development
PORT=3000
API_PREFIX=api
LOG_LEVEL=info

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dr_saleh_platform?schema=public

JWT_SECRET=replace-with-a-strong-secret-at-least-32-chars
JWT_EXPIRES_IN=1d

CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_CREDENTIALS=false

THROTTLE_TTL=60000
THROTTLE_LIMIT=100

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_TLS=false

S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false
