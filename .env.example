NODE_ENV=development
PORT=3000
API_PREFIX=api
LOG_LEVEL=info
SWAGGER_ENABLED=true

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dr_saleh_platform?schema=public
DATABASE_SSL_MODE=
PRISMA_QUERY_TIMEOUT_MS=30000

INITIAL_ADMIN_FULL_NAME="Platform Admin"
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PHONE_NUMBER=01000000000
INITIAL_ADMIN_PASSWORD=replace-with-a-strong-initial-admin-password

APP_PUBLIC_URL="http://localhost:3000"
APP_PLATFORM_URL="http://localhost:3000"
BRAND_LOGO_PATH="/brand/logo.png"
BRAND_NAME="Dr. Saleh Platform"
SUPPORT_EMAIL="support@drsaleh.com"
ADMIN_NOTIFICATION_EMAIL=

BREVO_API_KEY=
BREVO_SENDER_NAME="Dr. Saleh Platform"
BREVO_SENDER_EMAIL="no-reply@yourdomain.com"

JWT_ACCESS_SECRET=replace-with-a-strong-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=replace-with-a-strong-refresh-secret-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_CREDENTIALS=false

THROTTLE_TTL=60000
THROTTLE_LIMIT=100

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_TLS=false
REDIS_USERNAME=
REDIS_PASSWORD=

AWS_REGION=
AWS_S3_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT=
AWS_S3_FORCE_PATH_STYLE=false

CLOUDFRONT_DOMAIN=d27i48p63zrtq4.cloudfront.net
CLOUDFRONT_KEY_PAIR_ID=replace-with-cloudfront-key-pair-id
CLOUDFRONT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-cloudfront-private-key\n-----END PRIVATE KEY-----"

FAWRY_BASE_URL=https://atfawry.fawrystaging.com
FAWRY_MERCHANT_CODE=
FAWRY_SECURITY_KEY=
FAWRY_RETURN_URL=http://localhost:3000/payment/fawry/return
FAWRY_NOTIFICATION_URL=http://localhost:3000/api/payments/fawry/webhook

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com
PAYPAL_WEBHOOK_ID=

REFERRAL_REWARD_TYPE=PERCENTAGE
REFERRAL_REWARD_VALUE=10
REFERRAL_COUPON_EXPIRES_DAYS=30
