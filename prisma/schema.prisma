generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoleName {
  Admin
  User
}

enum OtpPurpose {
  EMAIL_VERIFICATION
  LOGIN
  PASSWORD_RESET
  CHANGE_EMAIL
}

enum Currency {
  EGP
  USD
}

enum BookFormatType {
  Physical @map("PHYSICAL")
  Digital  @map("DIGITAL")
  Audio    @map("AUDIO")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  CANCELED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentProvider {
  Fawry
  PayPal
  InternationalCard
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum WishlistItemType {
  COURSE
  BOOK
  PRODUCT
}

enum OrderItemType {
  COURSE
  BOOK
  PRODUCT
}

enum DeviceType {
  Mobile
  Tablet
  Desktop
}

enum ContentType {
  CourseVideo
  DigitalBook
  AudioBook
}

enum ConsultationGender {
  Male
  Female
}

enum Gender {
  Male
  Female
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        RoleName @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]

  @@map("roles")
}

model User {
  id                            String    @id @default(uuid()) @db.Uuid
  roleId                        String    @db.Uuid
  firstName                     String?
  lastName                      String?
  fullName                      String
  email                         String    @unique
  phoneNumber                   String    @unique
  passwordHash                  String
  profileImage                  String?
  gender                        Gender?
  dateOfBirth                   DateTime?
  isEmailVerified               Boolean   @default(false)
  emailVerifiedAt               DateTime?
  isPhoneVerified               Boolean   @default(false)
  phoneVerifiedAt               DateTime?
  lastLoginAt                   DateTime?
  emailVerificationOtpHash      String?
  emailVerificationOtpExpiresAt DateTime?
  emailVerificationOtpSentAt    DateTime?
  emailVerificationAttempts     Int       @default(0)
  passwordResetOtpHash          String?
  passwordResetOtpExpiresAt     DateTime?
  passwordResetOtpSentAt        DateTime?
  passwordResetAttempts         Int       @default(0)
  hashedRefreshToken            String?
  isActive                      Boolean   @default(true)
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt

  role                Role                 @relation(fields: [roleId], references: [id])
  addresses           UserAddress[]
  emailOtps           EmailOtp[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  userDevices         UserDevice[]
  contentSessions     ContentSession[]
  courseEnrollments   CourseEnrollment[]
  courseReviews       CourseReview[]
  certificates        Certificate[]
  bookReviews         BookReview[]
  cart                Cart?
  orders              Order[]
  couponUsages        CouponUsage[]
  referralsSent       Referral[]           @relation("ReferrerUser")
  referralReceived    Referral?            @relation("ReferredUser")
  wishlists           Wishlist[]

  @@index([roleId])
  @@map("users")
}

model UserAddress {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @db.Uuid
  countryId             String   @db.Uuid
  cityId                String   @db.Uuid
  shippingGovernorateId String?  @db.Uuid
  label                 String?
  fullName              String
  phoneNumber           String
  state                 String
  addressLine1          String
  addressLine2          String?
  city                  String
  postalCode            String?
  country               String   @default("EG")
  latitude              Decimal? @db.Decimal(9, 6)
  longitude             Decimal? @db.Decimal(9, 6)
  notes                 String?
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                User                 @relation(fields: [userId], references: [id])
  addressCountry      Country              @relation(fields: [countryId], references: [id])
  addressCity         City                 @relation(fields: [cityId], references: [id])
  shippingGovernorate ShippingGovernorate? @relation(fields: [shippingGovernorateId], references: [id])
  orders              Order[]

  @@index([userId])
  @@index([countryId])
  @@index([cityId])
  @@index([shippingGovernorateId])
  @@map("user_addresses")
}

model Country {
  id           String   @id @default(uuid()) @db.Uuid
  nameAr       String
  nameEn       String
  isoCode      String   @unique
  phoneCode    String
  currencyCode String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  cities        City[]
  userAddresses UserAddress[]

  @@map("countries")
}

model City {
  id        String   @id @default(uuid()) @db.Uuid
  countryId String   @db.Uuid
  nameAr    String
  nameEn    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  country       Country       @relation(fields: [countryId], references: [id])
  userAddresses UserAddress[]

  @@unique([countryId, nameEn])
  @@index([countryId])
  @@map("cities")
}

model EmailOtp {
  id            String     @id @default(uuid()) @db.Uuid
  userId        String?    @db.Uuid
  email         String
  purpose       OtpPurpose
  codeHash      String
  expiresAt     DateTime
  verifiedAt    DateTime?
  consumedAt    DateTime?
  attemptsCount Int        @default(0)
  createdAt     DateTime   @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([email, purpose])
  @@index([email, purpose, expiresAt])
  @@map("email_otps")
}

model RefreshToken {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  userDeviceId String?   @db.Uuid
  tokenHash    String    @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user       User        @relation(fields: [userId], references: [id])
  userDevice UserDevice? @relation(fields: [userDeviceId], references: [id])

  @@index([userId])
  @@index([userDeviceId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("password_reset_tokens")
}

model UserDevice {
  id               String     @id @default(uuid()) @db.Uuid
  userId           String     @db.Uuid
  deviceType       DeviceType
  deviceIdentifier String
  deviceName       String?
  pushToken        String?
  lastSeenAt       DateTime?
  isActive         Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  user            User             @relation(fields: [userId], references: [id])
  refreshTokens   RefreshToken[]
  contentSessions ContentSession[]

  @@unique([userId, deviceIdentifier])
  @@index([userId])
  @@map("user_devices")
}

model ContentSession {
  id             String      @id @default(uuid()) @db.Uuid
  userId         String      @db.Uuid
  userDeviceId   String      @db.Uuid
  contentType    ContentType
  courseVideoId  String?     @db.Uuid
  bookFormatId   String?     @db.Uuid
  sessionKey     String      @unique
  startedAt      DateTime    @default(now())
  lastActivityAt DateTime    @default(now())
  expiresAt      DateTime
  endedAt        DateTime?
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user        User         @relation(fields: [userId], references: [id])
  userDevice  UserDevice   @relation(fields: [userDeviceId], references: [id])
  courseVideo CourseVideo? @relation(fields: [courseVideoId], references: [id])
  bookFormat  BookFormat?  @relation(fields: [bookFormatId], references: [id])

  @@index([userId])
  @@index([userDeviceId])
  @@index([courseVideoId])
  @@index([bookFormatId])
  @@index([userId, isActive])
  @@map("content_sessions")
}

model CourseCategory {
  id            String   @id @default(uuid()) @db.Uuid
  nameAr        String
  nameEn        String
  slug          String   @unique
  descriptionAr String?
  descriptionEn String?
  image         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  courses Course[]

  @@map("course_categories")
}

model Course {
  id                 String   @id @default(uuid()) @db.Uuid
  courseCategoryId   String   @db.Uuid
  slug               String   @unique
  titleAr            String
  titleEn            String
  shortDescriptionAr String
  shortDescriptionEn String
  descriptionAr      String
  descriptionEn      String
  image              String
  promoVideo         String?
  priceEgp           Decimal  @db.Decimal(12, 2)
  priceUsd           Decimal  @db.Decimal(12, 2)
  discountPriceEgp   Decimal? @db.Decimal(12, 2)
  discountPriceUsd   Decimal? @db.Decimal(12, 2)
  isRibbon           Boolean  @default(false)
  ribbonText         String?
  ribbonColor        String?
  isHomeDisplay      Boolean  @default(false)
  isDisplayed        Boolean  @default(true)
  isActive           Boolean  @default(true)
  numberOfLessons    Int      @default(0)
  durationMinutes    Int      @default(0)
  rating             Decimal  @default(0) @db.Decimal(3, 2)
  reviewsCount       Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  courseCategory CourseCategory     @relation(fields: [courseCategoryId], references: [id])
  curriculums    Curriculum[]
  enrollments    CourseEnrollment[]
  reviews        CourseReview[]
  certificates   Certificate[]
  cartItems      CartItem[]
  orderItems     OrderItem[]

  @@index([courseCategoryId])
  @@index([isActive, isDisplayed])
  @@index([isHomeDisplay])
  @@map("courses")
}

model Curriculum {
  id            String   @id @default(uuid()) @db.Uuid
  courseId      String   @db.Uuid
  titleAr       String
  titleEn       String
  descriptionAr String?
  descriptionEn String?
  position      Int
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  course       Course        @relation(fields: [courseId], references: [id])
  courseVideos CourseVideo[]

  @@unique([courseId, position])
  @@index([courseId])
  @@map("curriculums")
}

model CourseVideo {
  id              String   @id @default(uuid()) @db.Uuid
  curriculumId    String   @db.Uuid
  titleAr         String
  titleEn         String
  descriptionAr   String?
  descriptionEn   String?
  videoUrl        String
  durationSeconds Int
  position        Int
  isPreview       Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  curriculum      Curriculum       @relation(fields: [curriculumId], references: [id])
  courseProgress  CourseProgress[]
  contentSessions ContentSession[]

  @@unique([curriculumId, position])
  @@index([curriculumId])
  @@map("course_videos")
}

model CourseEnrollment {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @db.Uuid
  courseId        String    @db.Uuid
  orderItemId     String?   @unique @db.Uuid
  progressPercent Decimal   @default(0) @db.Decimal(5, 2)
  enrolledAt      DateTime  @default(now())
  expiresAt       DateTime?
  completedAt     DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user           User             @relation(fields: [userId], references: [id])
  course         Course           @relation(fields: [courseId], references: [id])
  orderItem      OrderItem?       @relation(fields: [orderItemId], references: [id])
  courseProgress CourseProgress[]
  certificate    Certificate?

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("course_enrollments")
}

model CourseProgress {
  id                 String    @id @default(uuid()) @db.Uuid
  courseEnrollmentId String    @db.Uuid
  courseVideoId      String    @db.Uuid
  watchedSeconds     Int       @default(0)
  isCompleted        Boolean   @default(false)
  completedAt        DateTime?
  lastWatchedAt      DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  courseEnrollment CourseEnrollment @relation(fields: [courseEnrollmentId], references: [id])
  courseVideo      CourseVideo      @relation(fields: [courseVideoId], references: [id])

  @@unique([courseEnrollmentId, courseVideoId])
  @@index([courseEnrollmentId])
  @@index([courseVideoId])
  @@map("course_progress")
}

model CourseReview {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  courseId  String   @db.Uuid
  rating    Int      @db.SmallInt
  title     String?
  comment   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("course_reviews")
}

model Certificate {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @db.Uuid
  courseId           String   @db.Uuid
  courseEnrollmentId String   @unique @db.Uuid
  certificateNumber  String   @unique
  fileUrl            String?
  issuedAt           DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user             User             @relation(fields: [userId], references: [id])
  course           Course           @relation(fields: [courseId], references: [id])
  courseEnrollment CourseEnrollment @relation(fields: [courseEnrollmentId], references: [id])

  @@index([userId])
  @@index([courseId])
  @@map("certificates")
}

model BookCategory {
  id        String   @id @default(uuid()) @db.Uuid
  nameAr    String
  nameEn    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  books Book[]

  @@map("book_categories")
}

model Book {
  id               String   @id @default(uuid()) @db.Uuid
  bookCategoryId   String   @db.Uuid
  slug             String   @unique
  titleAr          String
  titleEn          String
  descriptionAr    String
  descriptionEn    String
  coverImage       String
  priceEgp         Decimal  @db.Decimal(12, 2)
  priceUsd         Decimal  @db.Decimal(12, 2)
  discountPriceEgp Decimal? @db.Decimal(12, 2)
  discountPriceUsd Decimal? @db.Decimal(12, 2)
  isFeatured       Boolean  @default(false)
  isHomeDisplay    Boolean  @default(false)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  bookCategory BookCategory @relation(fields: [bookCategoryId], references: [id])
  bookFormats  BookFormat[]
  bookImages   BookImage[]
  bookReviews  BookReview[]

  @@index([bookCategoryId])
  @@index([isHomeDisplay])
  @@map("books")
}

model BookImage {
  id           String   @id @default(uuid()) @db.Uuid
  bookId       String   @db.Uuid
  imageUrl     String
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())

  book Book @relation(fields: [bookId], references: [id])

  @@index([bookId])
  @@map("book_images")
}

model BookFormat {
  id               String         @id @default(uuid()) @db.Uuid
  bookId           String         @db.Uuid
  formatType       BookFormatType
  sku              String?        @unique
  stock            Int?
  weight           Decimal?       @db.Decimal(8, 2)
  priceEgp         Decimal?       @db.Decimal(12, 2)
  discountPriceEgp Decimal?       @db.Decimal(12, 2)
  priceUsd         Decimal?       @db.Decimal(12, 2)
  discountPriceUsd Decimal?       @db.Decimal(12, 2)
  readerFile       String?
  audioFile        String?
  audioDuration    Int?
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  book            Book             @relation(fields: [bookId], references: [id])
  cartItems       CartItem[]
  orderItems      OrderItem[]
  contentSessions ContentSession[]

  @@unique([bookId, formatType])
  @@index([bookId])
  @@map("book_formats")
}

model BookReview {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  bookId    String   @db.Uuid
  rating    Int      @db.SmallInt
  title     String?
  comment   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  book Book @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId])
  @@index([userId])
  @@index([bookId])
  @@map("book_reviews")
}

model ProductCategory {
  id        String   @id @default(uuid()) @db.Uuid
  nameAr    String
  nameEn    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@map("product_categories")
}

model Product {
  id               String   @id @default(uuid()) @db.Uuid
  categoryId       String   @db.Uuid
  nameAr           String
  nameEn           String
  slug             String   @unique
  descriptionAr    String
  descriptionEn    String
  coverImage       String
  priceEgp         Decimal  @db.Decimal(12, 2)
  discountPriceEgp Decimal? @db.Decimal(12, 2)
  priceUsd         Decimal  @db.Decimal(12, 2)
  discountPriceUsd Decimal? @db.Decimal(12, 2)
  stock            Int      @default(0)
  sku              String?  @unique
  isFeatured       Boolean  @default(false)
  isHomeDisplay    Boolean  @default(false)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  category   ProductCategory @relation(fields: [categoryId], references: [id])
  images     ProductImage[]
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([categoryId])
  @@index([isActive, createdAt])
  @@index([isFeatured])
  @@index([isHomeDisplay])
  @@map("products")
}

model ProductImage {
  id           String   @id @default(uuid()) @db.Uuid
  productId    String   @db.Uuid
  imageUrl     String
  displayOrder Int
  createdAt    DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@map("product_images")
}

model Cart {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id])
  cartItems CartItem[]

  @@map("carts")
}

model CartItem {
  id           String        @id @default(uuid()) @db.Uuid
  cartId       String        @db.Uuid
  itemType     OrderItemType
  courseId     String?       @db.Uuid
  bookFormatId String?       @db.Uuid
  productId    String?       @db.Uuid
  quantity     Int           @default(1)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  cart       Cart        @relation(fields: [cartId], references: [id])
  course     Course?     @relation(fields: [courseId], references: [id])
  bookFormat BookFormat? @relation(fields: [bookFormatId], references: [id])
  product    Product?    @relation(fields: [productId], references: [id])

  @@unique([cartId, courseId])
  @@unique([cartId, bookFormatId])
  @@unique([cartId, productId])
  @@index([cartId])
  @@index([courseId])
  @@index([bookFormatId])
  @@index([productId])
  @@map("cart_items")
}

model Order {
  id                    String        @id @default(uuid()) @db.Uuid
  userId                String        @db.Uuid
  orderNumber           String        @unique
  status                OrderStatus   @default(PENDING)
  paymentStatus         PaymentStatus @default(PENDING)
  currency              Currency
  couponId              String?       @db.Uuid
  shippingGovernorateId String?       @db.Uuid
  shippingAddressId     String?       @db.Uuid
  shippingFullName      String?
  shippingPhoneNumber   String?
  shippingAddressLine1  String?
  shippingAddressLine2  String?
  shippingCity          String?
  shippingPostalCode    String?
  shippingCountry       String?
  subtotal              Decimal       @db.Decimal(12, 2)
  discountAmount        Decimal       @default(0) @db.Decimal(12, 2)
  couponDiscountAmount  Decimal       @default(0) @db.Decimal(12, 2)
  shippingCost          Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount           Decimal       @db.Decimal(12, 2)
  notes                 String?
  placedAt              DateTime      @default(now())
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user                User                 @relation(fields: [userId], references: [id])
  coupon              Coupon?              @relation(fields: [couponId], references: [id])
  shippingGovernorate ShippingGovernorate? @relation(fields: [shippingGovernorateId], references: [id])
  shippingAddress     UserAddress?         @relation(fields: [shippingAddressId], references: [id])
  orderItems          OrderItem[]
  paymentTransactions PaymentTransaction[]
  couponUsage         CouponUsage?
  refunds             Refund[]

  @@index([userId])
  @@index([couponId])
  @@index([shippingGovernorateId])
  @@index([shippingAddressId])
  @@index([status])
  @@index([paymentStatus])
  @@map("orders")
}

model OrderItem {
  id                String        @id @default(uuid()) @db.Uuid
  orderId           String        @db.Uuid
  itemType          OrderItemType
  courseId          String?       @db.Uuid
  bookFormatId      String?       @db.Uuid
  productId         String?       @db.Uuid
  quantity          Int           @default(1)
  unitPrice         Decimal       @db.Decimal(12, 2)
  discountUnitPrice Decimal?      @db.Decimal(12, 2)
  lineTotal         Decimal       @db.Decimal(12, 2)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  order            Order             @relation(fields: [orderId], references: [id])
  course           Course?           @relation(fields: [courseId], references: [id])
  bookFormat       BookFormat?       @relation(fields: [bookFormatId], references: [id])
  product          Product?          @relation(fields: [productId], references: [id])
  courseEnrollment CourseEnrollment?

  @@unique([orderId, courseId])
  @@unique([orderId, bookFormatId])
  @@unique([orderId, productId])
  @@index([orderId])
  @@index([courseId])
  @@index([bookFormatId])
  @@index([productId])
  @@map("order_items")
}

model ShippingGovernorate {
  id           String   @id @default(uuid()) @db.Uuid
  nameAr       String
  nameEn       String
  slug         String   @unique
  shippingCost Decimal  @db.Decimal(12, 2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userAddresses UserAddress[]
  orders        Order[]

  @@map("shipping_governorates")
}

model PaymentTransaction {
  id                    String          @id @default(uuid()) @db.Uuid
  orderId               String          @db.Uuid
  provider              PaymentProvider
  status                PaymentStatus   @default(PENDING)
  amount                Decimal         @db.Decimal(12, 2)
  currency              Currency
  transactionReference  String          @unique
  providerTransactionId String?         @unique
  providerResponse      Json?
  failureReason         String?
  paidAt                DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  order   Order    @relation(fields: [orderId], references: [id])
  refunds Refund[]

  @@index([orderId])
  @@map("payment_transactions")
}

model Refund {
  id                   String        @id @default(uuid()) @db.Uuid
  orderId              String        @db.Uuid
  paymentTransactionId String        @db.Uuid
  refundReference      String        @unique
  providerRefundId     String?       @unique
  amount               Decimal       @db.Decimal(12, 2)
  currency             Currency
  status               PaymentStatus @default(PENDING)
  reason               String?
  processedAt          DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  order              Order              @relation(fields: [orderId], references: [id])
  paymentTransaction PaymentTransaction @relation(fields: [paymentTransactionId], references: [id])

  @@index([orderId])
  @@index([paymentTransactionId])
  @@map("refunds")
}

model Coupon {
  id                    String     @id @default(uuid()) @db.Uuid
  code                  String     @unique
  title                 String?
  description           String?
  couponType            CouponType
  value                 Decimal    @db.Decimal(12, 2)
  currency              Currency?
  minimumOrderAmount    Decimal?   @db.Decimal(12, 2)
  maximumDiscountAmount Decimal?   @db.Decimal(12, 2)
  usageLimit            Int?
  usagePerUserLimit     Int?
  usedCount             Int        @default(0)
  startsAt              DateTime
  expiresAt             DateTime
  isActive              Boolean    @default(true)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  orders       Order[]
  couponUsages CouponUsage[]

  @@index([code, isActive])
  @@index([startsAt, expiresAt])
  @@map("coupons")
}

model CouponUsage {
  id             String   @id @default(uuid()) @db.Uuid
  couponId       String   @db.Uuid
  userId         String   @db.Uuid
  orderId        String   @unique @db.Uuid
  discountAmount Decimal  @db.Decimal(12, 2)
  currency       Currency
  usedAt         DateTime @default(now())
  createdAt      DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
  order  Order  @relation(fields: [orderId], references: [id])

  @@index([couponId])
  @@index([userId])
  @@index([userId, couponId])
  @@map("coupon_usages")
}

model Referral {
  id              String    @id @default(uuid()) @db.Uuid
  referrerUserId  String    @db.Uuid
  referredUserId  String    @unique @db.Uuid
  isRewardGranted Boolean   @default(false)
  rewardGrantedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  referrerUser User @relation("ReferrerUser", fields: [referrerUserId], references: [id])
  referredUser User @relation("ReferredUser", fields: [referredUserId], references: [id])

  @@index([referrerUserId])
  @@map("referrals")
}

model Wishlist {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  itemType  WishlistItemType
  itemId    String           @db.Uuid
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, itemType, itemId])
  @@index([userId])
  @@index([itemType])
  @@index([itemId])
  @@map("wishlists")
}

model ArticleCategory {
  id        String   @id @default(uuid()) @db.Uuid
  nameAr    String
  nameEn    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  articles Article[]

  @@map("article_categories")
}

model Article {
  id             String   @id @default(uuid()) @db.Uuid
  categoryId     String   @db.Uuid
  titleAr        String
  titleEn        String
  slug           String   @unique
  shortContentAr String
  shortContentEn String
  contentAr      String
  contentEn      String
  coverImage     String
  viewsCount     Int      @default(0)
  isFeatured     Boolean  @default(false)
  isHomeDisplay  Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  category     ArticleCategory      @relation(fields: [categoryId], references: [id])
  tagRelations ArticleTagRelation[]

  @@index([categoryId])
  @@index([isActive, createdAt])
  @@index([isFeatured])
  @@index([isHomeDisplay])
  @@map("articles")
}

model ArticleTag {
  id        String   @id @default(uuid()) @db.Uuid
  nameAr    String
  nameEn    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tagRelations ArticleTagRelation[]

  @@map("article_tags")
}

model ArticleTagRelation {
  articleId String @db.Uuid
  tagId     String @db.Uuid

  article Article    @relation(fields: [articleId], references: [id])
  tag     ArticleTag @relation(fields: [tagId], references: [id])

  @@id([articleId, tagId])
  @@index([articleId])
  @@index([tagId])
  @@map("article_tag_relations")
}

model ConsultationCategory {
  id        String   @id @default(uuid()) @db.Uuid
  nameAr    String
  nameEn    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  consultationRequests ConsultationRequest[]

  @@map("consultation_categories")
}

model ConsultationRequest {
  id                String             @id @default(uuid()) @db.Uuid
  categoryId        String             @db.Uuid
  fullName          String
  age               Int
  gender            ConsultationGender
  country           String
  phone             String
  whatsApp          String
  email             String
  consultationTopic String
  notes             String?
  createdAt         DateTime           @default(now())

  category ConsultationCategory @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([phone])
  @@index([whatsApp])
  @@index([email])
  @@index([createdAt])
  @@map("consultation_requests")
}

model ContactMessage {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String
  phone     String
  message   String
  isOpened  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([phone])
  @@index([isOpened])
  @@index([createdAt])
  @@map("contact_messages")
}
